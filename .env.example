# BioAI-Pulse — Environment Variables
# Skopiuj ten plik jako .env i uzupełnij wartości.
# NIE commituj pliku .env do repozytorium.

# --- Groq API (darmowy, Llama 3.3 70B) ---
# Pobierz klucz ze: https://console.groq.com/keys
GROQ_API_KEY=twój_klucz_groq_tutaj

# --- Fitbit / Google OAuth 2.0 ---
# Uzyskaj ze: https://dev.fitbit.com/apps/new
FITBIT_CLIENT_ID=twój_client_id_tutaj
FITBIT_CLIENT_SECRET=twój_client_secret_tutaj
FITBIT_REDIRECT_URI=https://franek-health.duckdns.org:8080/callback

# SSL (Let's Encrypt — ścieżki na VPS)
SSL_CERTFILE=/etc/letsencrypt/live/franek-health.duckdns.org/fullchain.pem
SSL_KEYFILE=/etc/letsencrypt/live/franek-health.duckdns.org/privkey.pem

# --- Aplikacja / PWA (api/index.py — te same zmienne ustaw w panelu Vercela) ---
APP_PIN=2137                                   # PIN do logowania w apce — ZMIEŃ
APP_SECRET=zmien-mnie-na-dlugi-losowy-ciag     # podpis tokenów logowania — ZMIEŃ
CRON_SECRET=zmien-mnie                         # zabezpiecza /api/cron/reminders

# Powiadomienia push (wygeneruj: python3 app/generate_vapid.py)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:zgnilyziemniak123@gmail.com

# Vercel KV (ustawia się automatycznie po włączeniu KV w panelu Vercela) —
# potrzebne, by subskrypcje push przetrwały między wywołaniami serverless:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# DEMO_MODE=1                                   # wymuś dane demo (odkomentuj do testów)
